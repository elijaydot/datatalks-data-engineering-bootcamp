        "expr": "sum(producer_errors_total) or vector(0)",
        "legendFormat": "Errors",
        "refId": "A"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
